NODE_ENV=development
PORT=5000
MONGODB_URI=mongodb://localhost:27017/shopverse
CLIENT_URL=http://localhost:5173

JWT_ACCESS_SECRET=change-me-access-min-32-chars-long!!
JWT_REFRESH_SECRET=change-me-refresh-min-32-chars-long!!
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Optional — product image upload (https://cloudinary.com)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Optional — order confirmation email (Resend preferred: https://resend.com)
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM=ShopVerse <orders@yourdomain.com>

# Optional — SMTP fallback (Gmail, SendGrid SMTP, Mailtrap, etc.)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
